# Server Environment Variables
# Copy this file to .env and update values

# Server Configuration
PORT=5000
NODE_ENV=development

# MongoDB Connection
# Local: mongodb://localhost:27017/usermgmt
# Atlas: mongodb+srv://<user>:<password>@<cluster>/<database>
MONGO_URI=mongodb://localhost:27017/usermgmt

# JWT Configuration
# IMPORTANT: Use strong, unique secrets in production!
# Minimum 32 characters recommended
JWT_ACCESS_SECRET=your-access-secret-key-min-32-characters
JWT_REFRESH_SECRET=your-refresh-secret-key-min-32-characters

# Client Origin (for CORS)
# Development: http://localhost:5173
# Production: https://your-domain.com
CLIENT_ORIGIN=http://localhost:5173